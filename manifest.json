{
  "manifest_version": 3,
  "name": "Neckbeard",
  "version": "0.1.0",
  "description": "There is no escape.",
  "permissions": ["storage"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background/background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "config/tunables.js",
        "content/game-state.js",
        "content/sprites.js",
        "content/physics.js",
        "content/ui-overlay.js",
        "content/spawn-logic.js",
        "content/accessibility.js",
        "debug/debug-harness.js",
        "content/content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}

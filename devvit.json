{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "neckbeard-go",
  "post": {
    "dir": "dist/client",
    "entrypoints": {
      "default": {
        "inline": true,
        "entry": "splash.html"
      },
      "game": {
        "entry": "game.html"
      }
    }
  },
  "server": {
    "dir": "dist/server",
    "entry": "index.cjs"
  },
  "menu": {
    "items": [
      {
        "label": "Create Neckbeard post",
        "description": "Post the game to this subreddit",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/post-create"
      }
    ]
  },
  "scripts": {
    "build": "node tools/build-devvit.mjs",
    "dev": "node tools/build-devvit.mjs && devvit playtest"
  }
}